# TimescaleDB connection settings
TSDB_HOST=
TSDB_PORT=5432
TSDB_NAME=
TSDB_USER=
TSDB_PASSWORD=

# Optional SSL mode, if required by deployment
# TSDB_SSLMODE=

# DB logging
TSDB_LOG_SQL=1
TSDB_LOG_DEBUG=0

# DB write controls
# Keep disabled by default. Set to 1 only when intentionally testing DB writes.
TSDB_EXECUTE_WRITES=0

# Background HF writes
TSDB_BACKGROUND_HF_WRITES=1

# QCSoft DB overlay/save behavior
TSDB_OVERLAY_MAX_MONTHS=4
TSDB_SAVE_GATE_WATCHDOG_MS=120000
